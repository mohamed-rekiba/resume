{
  "name": "resume",
  "version": "1.7.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "prebuild": "npm run update-meta",
    "update-meta": "node --experimental-strip-types scripts/update-meta.ts",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,scss,html}\" \"e2e/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss,html}\" \"e2e/**/*.ts\"",
    "precommit": "pre-commit run --all-files",
    "precommit:staged": "pre-commit run",
    "pdf": "npx playwright test && echo 'PDFs saved to e2e-results/ (resume.pdf + resume-<target>.pdf per target)'",
    "prepare": "husky"
  },
  "type": "module",
  "private": true,
  "packageManager": "npm@11.16.0",
  "overrides": {
    "qs": "6.15.2"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "js-yaml": "^4.2.0",
    "marked": "^18.0.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}
